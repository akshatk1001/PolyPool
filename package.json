{
  "name": "nodedemons",
  "version": "1.0.0",
  "description": "CSC 307 Final Project",
  "homepage": "https://github.com/akshatk1001/NodeDemons#readme",
  "bugs": {
    "url": "https://github.com/akshatk1001/NodeDemons/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akshatk1001/NodeDemons.git"
  },
  "license": "ISC",
  "author": "Akshat, Danny, Kody",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "lint": "npx eslint . && npx prettier --check .",
    "test": "jest",
    "test:comp": "jest",
    "test:coverage:searchbar": "jest packages/react-frontend/src/tests/SearchBar.test.js --coverage --collectCoverageFrom=packages/react-frontend/src/SearchBar.jsx --runInBand",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "start": "npm run dev --workspace=packages/react-frontend"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "babel": "^5.8.38",
    "babel-jest": "^30.3.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1"
  },
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/test/jest.setup.js"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            "@babel/preset-env",
            [
              "@babel/preset-react",
              {
                "runtime": "automatic"
              }
            ]
          ]
        }
      ]
    },
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/test/styleMock.js",
      "\\.(png|jpe?g|gif|webp|svg)$": "<rootDir>/test/fileMock.js"
    }
  },
  "babel": {
    "presets": [
      "@babel/preset-react"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.2",
    "csv-parser": "^3.2.0",
    "node": "^25.7.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1"
  }
}
