MONGO_CONNECTION_STRING= click clusters -> connect -> drivers & copy the string under "Add your connection string into your application code"
# IMPORTANT: ^^^ADD '/polypool' before ?appName=PolyPool-Cluster to the end of the connection string^^^

# Microsoft SSO
MICROSOFT_CLIENT_ID=application-client-id
MICROSOFT_CLIENT_SECRET=client-secret-value

# session secret: any long random string
SESSION_SECRET=some-long-random-string
# i generated using: `console.log(require('crypto').randomBytes(32).toString('hex'))`

#  Make sure to set to production in deployment
NODE_ENV=development

# URLs (defaults to localhost if not set)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# Make sure to set in prof to actual URL's